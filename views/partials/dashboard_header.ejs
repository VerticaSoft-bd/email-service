<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | MailFlow SaaS' : 'Dashboard' %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 antialiased flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <div class="hidden md:flex md:flex-shrink-0">
        <div class="flex flex-col w-64">
            <div class="flex flex-col flex-grow pt-5 pb-4 overflow-y-auto bg-white border-r border-gray-200">
                <div class="flex items-center flex-shrink-0 px-4">
                    <a href="/dashboard" class="text-2xl font-bold text-indigo-600">MailFlow SaaS</a>
                </div>
                <div class="mt-8 flex-1 flex flex-col">
                    <nav class="flex-1 px-2 bg-white space-y-1">
                        <% const path=typeof currentPath !=='undefined' ? currentPath : '/dashboard' ; %>
                            <a href="/dashboard"
                                class="<%= path === '/dashboard' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="home"
                                    class="<%= path === '/dashboard' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                Overview
                            </a>
                            <a href="/dashboard/domains"
                                class="<%= path === '/dashboard/domains' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="globe"
                                    class="<%= path === '/dashboard/domains' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                Domains
                            </a>
                            <a href="/dashboard/accounts"
                                class="<%= path === '/dashboard/accounts' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="mail"
                                    class="<%= path === '/dashboard/accounts' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                Email Accounts
                            </a>
                            <a href="/dashboard/send"
                                class="<%= path === '/dashboard/send' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="send"
                                    class="<%= path === '/dashboard/send' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                Send Email
                            </a>
                            <a href="/dashboard/logs"
                                class="<%= path === '/dashboard/logs' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="list"
                                    class="<%= path === '/dashboard/logs' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                Email Logs
                            </a>
                    </nav>

                    <!-- Added Developer Secion -->
                    <div class="mt-8">
                        <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                            id="developer-headline">
                            Developer
                        </h3>
                        <nav class="mt-2 space-y-1" aria-labelledby="developer-headline">
                            <a href="/dashboard/docs"
                                class="<%= path === '/dashboard/docs' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-3 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="file-code-2"
                                    class="<%= path === '/dashboard/docs' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                API Docs
                            </a>
                            <a href="/dashboard/apikeys"
                                class="<%= path === '/dashboard/apikeys' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-3 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="key"
                                    class="<%= path === '/dashboard/apikeys' ? 'text-indigo-600' : 'text-gray-400 group-hover:text-gray-500' %> mr-3 flex-shrink-0 h-5 w-5"></i>
                                API Keys
                            </a>
                        </nav>
                    </div>
                    <% if (user.role==='admin' ) { %>
                        <div class="mt-8 pt-4">
                            <div class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                                Admin</div>
                            <a href="/dashboard/admin"
                                class="<%= path === '/dashboard/admin' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                                <i data-lucide="shield"
                                    class="text-gray-400 group-hover:text-gray-500 mr-3 flex-shrink-0 h-5 w-5"></i>
                                Admin Panel
                            </a>
                        </div>
                        <% } %>
                            </nav>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col w-0 flex-1 overflow-hidden">
        <div class="relative z-10 flex-shrink-0 flex h-16 bg-white shadow-sm border-b border-gray-200">
            <div class="flex-1 px-4 flex justify-between">
                <div class="flex-1 flex"></div>
                <div class="ml-4 flex items-center md:ml-6">
                    <div class="ml-3 relative flex items-center space-x-4">
                        <span class="text-sm font-medium text-gray-700">
                            <%= user.name %>
                        </span>
                        <a href="/auth/logout" class="text-sm text-gray-500 hover:text-gray-700">Logout</a>
                    </div>
                </div>
            </div>
        </div>

        <main class="flex-1 relative overflow-y-auto focus:outline-none">
            <div class="py-6">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">