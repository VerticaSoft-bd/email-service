        <!-- Background Gradients -->
        <div
            class="absolute w-full max-w-lg -top-20 -left-20 xl:-top-20 xl:-left-20 opacity-30 mix-blend-multiply filter blur-2xl animate-blob bg-indigo-300 rounded-full h-96">
        </div>
        <div
