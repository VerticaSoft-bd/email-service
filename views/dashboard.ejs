<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — Email SaaS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
    <div class="page page--wide">
        <div class="blob blob--1"></div>
        <div class="blob blob--2"></div>

        <main class="dashboard" id="dashboard">
            <!-- Header -->
            <div class="dash-header">
                <div class="dash-header__left">
                    <div class="logo">
                        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="4" width="20" height="16" rx="2" />
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                        </svg>
                    </div>
                    <div>
                        <h1>Dashboard</h1>
                        <p class="subtitle">Welcome, <strong>
                                <%= user.name %>
                            </strong></p>
                    </div>
                </div>
                <div class="dash-header__right">
                    <span class="badge <%= user.domainVerified ? 'badge--success' : 'badge--pending' %>"
                        id="domain-status-badge">
                        <%= user.domainVerified ? '✓ Verified' : '⏳ Pending' %>
                    </span>
                </div>
            </div>

            <!-- Alerts -->
            <% if (statusMessage) { %>
                <div class="alert alert--success" id="alert-status"><span>
                        <%= statusMessage %>
                    </span></div>
                <% } %>
                    <% if (error) { %>
                        <div class="alert alert--error" id="alert-error"><span>
                                <%= error %>
                            </span></div>
                        <% } %>

                            <!-- User Info -->
                            <section class="section">
                                <h2 class="section__title">Account Info</h2>
                                <div class="info-grid">
                                    <div class="info-card">
                                        <span class="info-card__label">Sender Email</span>
                                        <span class="info-card__value">
                                            <%= user.senderEmail %>
                                        </span>
                                    </div>
                                    <div class="info-card">
                                        <span class="info-card__label">Domain</span>
                                        <span class="info-card__value">
                                            <%= user.domain %>
                                        </span>
                                    </div>
                                </div>
                            </section>

                            <!-- Domain Verification -->
                            <section class="section">
                                <div class="section__header">
                                    <h2 class="section__title">Domain Verification</h2>
                                    <div class="section__actions">
                                        <% if (!user.verificationToken) { %>
                                            <form action="/domain/<%= user._id %>/verify" method="POST"
                                                style="display:inline">
                                                <button type="submit" class="btn btn--sm" id="verify-btn">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                                    </svg>
                                                    Verify Domain
                                                </button>
                                            </form>
                                            <% } %>
                                                <% if (user.verificationToken) { %>
                                                    <a href="/domain/<%= user._id %>/status"
                                                        class="btn btn--sm btn--outline" id="check-status-btn">
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="2"
                                                            stroke-linecap="round" stroke-linejoin="round">
                                                            <polyline points="23 4 23 10 17 10" />
                                                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                                                        </svg>
                                                        Check Status
                                                    </a>
                                                    <% } %>
                                    </div>
                                </div>

                                <% if (dnsRecords && dnsRecords.length> 0) { %>
                                    <p class="section__desc">Add these DNS records to your domain registrar:</p>
                                    <div class="table-wrap">
                                        <table class="dns-table" id="dns-records-table">
                                            <thead>
                                                <tr>
                                                    <th>Purpose</th>
                                                    <th>Type</th>
                                                    <th>Name</th>
                                                    <th>Value</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% dnsRecords.forEach((rec)=> { %>
                                                    <tr>
                                                        <td><span class="badge badge--info">
                                                                <%= rec.purpose %>
                                                            </span></td>
                                                        <td><code><%= rec.type %></code></td>
                                                        <td><code class="code--break"><%= rec.name %></code></td>
                                                        <td><code class="code--break"><%= rec.value %></code></td>
                                                        <td>
                                                            <button class="copy-btn"
                                                                onclick="copyText('<%= rec.value %>')"
                                                                title="Copy value">
                                                                <svg width="14" height="14" viewBox="0 0 24 24"
                                                                    fill="none" stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round">
                                                                    <rect x="9" y="9" width="13" height="13" rx="2"
                                                                        ry="2" />
                                                                    <path
                                                                        d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                                                                </svg>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } else { %>
                                        <div class="empty-state">
                                            <p>Click <strong>"Verify Domain"</strong> to initiate domain verification
                                                and get DNS records.</p>
                                        </div>
                                        <% } %>
                            </section>

                            <!-- Send Email -->
                            <% if (user.domainVerified) { %>
                                <section class="section">
                                    <h2 class="section__title">Send Email</h2>
                                    <form id="send-email-form" class="form form--inline">
                                        <input type="hidden" name="userId" value="<%= user._id %>" />
                                        <div class="form-row">
                                            <div class="field">
                                                <label for="to" class="field__label">To</label>
                                                <input type="email" id="to" name="to" class="field__input"
                                                    placeholder="recipient@example.com" required />
                                            </div>
                                            <div class="field">
                                                <label for="subject" class="field__label">Subject</label>
                                                <input type="text" id="subject" name="subject" class="field__input"
                                                    placeholder="Hello from Email SaaS!" required />
                                            </div>
                                        </div>
                                        <div class="field">
                                            <label for="body" class="field__label">Body (HTML supported)</label>
                                            <textarea id="body" name="body" class="field__input field__textarea"
                                                rows="4" placeholder="<h1>Hello!</h1><p>This is a test email...</p>"
                                                required></textarea>
                                        </div>
                                        <button type="submit" class="btn" id="send-btn">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                stroke-linejoin="round">
                                                <path d="M22 2 11 13" />
                                                <path d="m22 2-7 20-4-9-9-4 20-7z" />
                                            </svg>
                                            Send Email
                                        </button>
                                        <div id="send-result" class="send-result" style="display:none"></div>
                                    </form>
                                </section>
                                <% } %>

                                    <!-- Sent Emails -->
                                    <section class="section">
                                        <h2 class="section__title">Sent Emails</h2>
                                        <div class="table-wrap">
                                            <table class="dns-table" id="emails-table">
                                                <thead>
                                                    <tr>
                                                        <th>To</th>
                                                        <th>Subject</th>
                                                        <th>Status</th>
                                                        <th>Message ID</th>
                                                        <th>Sent At</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="emails-tbody">
                                                    <tr>
                                                        <td colspan="5" class="empty-state">Loading...</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </section>

                                    <!-- API Reference -->
                                    <section class="section">
                                        <h2 class="section__title">API Reference</h2>
                                        <div class="api-cards">
                                            <div class="api-card">
                                                <span class="badge badge--post">POST</span>
                                                <code>/api/send</code>
                                                <p>Send an email. Body: <code>{ userId, to, subject, body }</code></p>
                                            </div>
                                            <div class="api-card">
                                                <span class="badge badge--get">GET</span>
                                                <code>/api/emails/<%= user._id %></code>
                                                <p>List sent emails. Query: <code>?page=1&limit=20</code></p>
                                            </div>
                                            <div class="api-card">
                                                <span class="badge badge--get">GET</span>
                                                <code>/domain/<%= user._id %>/dns</code>
                                                <p>Get DNS records as JSON.</p>
                                            </div>
                                            <div class="api-card">
                                                <span class="badge badge--get">GET</span>
                                                <code>/domain/<%= user._id %>/status</code>
                                                <p>Check domain verification status.</p>
                                            </div>
                                        </div>
                                    </section>
        </main>

        <footer class="footer">
            <p>&copy; <%= new Date().getFullYear() %> Email SaaS &middot; Built with Express &amp; AWS SES</p>
        </footer>
    </div>

    <script>
        // Copy text to clipboard
        function copyText(text) {
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.createElement('div');
                toast.className = 'toast';
                toast.textContent = 'Copied!';
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 1500);
            });
        }

        // Load sent emails
        async function loadEmails() {
            try {
                const res = await fetch('/api/emails/<%= user._id %>');
                const data = await res.json();
                const tbody = document.getElementById('emails-tbody');

                if (!data.emails || data.emails.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No emails sent yet.</td></tr>';
                    return;
                }

                tbody.innerHTML = data.emails.map(e => `
          <tr>
            <td>${e.to}</td>
            <td>${e.subject}</td>
            <td><span class="badge badge--${e.status === 'sent' ? 'success' : e.status === 'failed' ? 'error' : 'pending'}">${e.status}</span></td>
            <td><code class="code--break">${e.messageId || '—'}</code></td>
            <td>${new Date(e.sentAt).toLocaleString()}</td>
          </tr>
        `).join('');
            } catch (err) {
                document.getElementById('emails-tbody').innerHTML =
                    '<tr><td colspan="5" class="empty-state">Error loading emails.</td></tr>';
            }
        }

        // Handle send email form
        const sendForm = document.getElementById('send-email-form');
        if (sendForm) {
            sendForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(sendForm);
                const body = Object.fromEntries(formData);
                const resultDiv = document.getElementById('send-result');

                try {
                    const res = await fetch('/api/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(body),
                    });
                    const data = await res.json();

                    resultDiv.style.display = 'block';
                    if (data.success) {
                        resultDiv.className = 'send-result send-result--success';
                        resultDiv.textContent = `✅ ${data.message} (ID: ${data.messageId})`;
                        sendForm.reset();
                        loadEmails();
                    } else {
                        resultDiv.className = 'send-result send-result--error';
                        resultDiv.textContent = `❌ ${data.error}`;
                    }
                } catch (err) {
                    resultDiv.style.display = 'block';
                    resultDiv.className = 'send-result send-result--error';
                    resultDiv.textContent = `❌ Network error: ${err.message}`;
                }
            });
        }

        // Load emails on page load
        loadEmails();
    </script>
</body>

</html>