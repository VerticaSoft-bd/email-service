<%- include('../../partials/dashboard_header', { title: 'Campaigns' , currentPath: '/dashboard/campaigns' }) %>

    <div class="sm:flex sm:items-center sm:justify-between mb-8">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">Bulk Campaigns</h1>
            <p class="mt-2 text-sm text-gray-700">Send personalized bulk emails to a list of recipients without hitting
                spam filters.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a href="/dashboard/campaigns/create"
                class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                <i data-lucide="plus" class="h-4 w-4 mr-2"></i> New Campaign
            </a>
        </div>
    </div>

    <div class="bg-white shadow overflow-hidden sm:rounded-md border border-gray-200">
        <% if (campaigns && campaigns.length> 0) { %>
            <ul role="list" class="divide-y divide-gray-200">
                <% campaigns.forEach(campaign=> { %>
                    <li>
                        <a href="/dashboard/campaigns/<%= campaign._id %>"
                            class="block hover:bg-gray-50 transition-colors">
                            <div class="px-4 py-4 sm:px-6">
                                <div class="flex items-center justify-between">
                                    <p class="text-sm font-medium text-indigo-600 truncate">
                                        <%= campaign.name %>
                                    </p>
                                    <div class="ml-2 flex-shrink-0 flex">
                                        <p class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                        <%= campaign.status === 'Completed' ? 'bg-green-100 text-green-800' : 
                                            campaign.status === 'Sending' ? 'bg-blue-100 text-blue-800' : 
                                            campaign.status === 'Draft' ? 'bg-gray-100 text-gray-800' : 
                                            'bg-yellow-100 text-yellow-800' %>">
                                            <%= campaign.status %>
                                        </p>
                                    </div>
                                </div>
                                <div class="mt-2 sm:flex sm:justify-between">
                                    <div class="sm:flex">
                                        <p class="flex items-center text-sm text-gray-500">
                                            <i data-lucide="users"
                                                class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400"></i>
                                            <%= campaign.totalRecipients %> Recipients
                                        </p>
                                    </div>
                                    <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                                        <i data-lucide="calendar"
                                            class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400"></i>
                                        <p>Created on <time datetime="<%= campaign.createdAt %>">
                                                <%= new Date(campaign.createdAt).toLocaleDateString() %>
                                            </time></p>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </li>
                    <% }) %>
            </ul>
            <% } else { %>
                <div class="text-center py-12">
                    <i data-lucide="megaphone" class="mx-auto h-12 w-12 text-gray-400"></i>
                    <h3 class="mt-2 text-sm font-medium text-gray-900">No campaigns found</h3>
                    <p class="mt-1 text-sm text-gray-500">Get started by creating a new email campaign.</p>
                </div>
                <% } %>
    </div>

    <%- include('../../partials/dashboard_footer') %>