<%- include('../partials/dashboard_header', { title: 'Suppression List' , currentPath: '/dashboard/suppressions' }) %>
    <div class="sm:flex sm:items-center justify-between">
        <div class="sm:flex-auto">
            <h1 class="text-2xl font-semibold text-gray-900">Suppression List</h1>
            <p class="mt-2 text-sm text-gray-700">Manage email addresses that have bounced, complained, or unsubscribed. Emails to these addresses will be automatically blocked to protect your sender reputation.</p>
        </div>
    </div>

    <div class="mt-8 flex flex-col">
        <% if (error) { %>
            <div class="mb-4 bg-red-50 border-l-4 border-red-400 p-4">
                <p class="text-sm text-red-700">
                    <%= error %>
                </p>
            </div>
        <% } %>

        <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
            <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
                <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
                    <table class="min-w-full divide-y divide-gray-300">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Email Address</th>
                                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
                                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Reason</th>
                                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Added On</th>
                                <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                                    <span class="sr-only">Actions</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            <% if (suppressions && suppressions.length > 0) { %>
                                <% suppressions.forEach(item => { %>
                                    <tr>
                                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                                            <%= item.email %>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                                                <%= item.type === 'bounce' ? 'bg-orange-100 text-orange-800' : 
                                                   item.type === 'complaint' ? 'bg-red-100 text-red-800' : 
                                                   'bg-gray-100 text-gray-800' %>">
                                                <%= item.type.charAt(0).toUpperCase() + item.type.slice(1) %>
                                            </span>
                                        </td>
                                        <td class="px-3 py-4 text-sm text-gray-500 max-w-xs truncate" title="<%= item.reason %>">
                                            <%= item.reason || 'No reason provided' %>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                                            <%= new Date(item.createdAt).toLocaleDateString() %>
                                        </td>
                                        <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                                            <form action="/dashboard/suppressions/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Are you sure you want to remove this email from the suppression list?')">
                                                <button type="submit" class="text-red-600 hover:text-red-900">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="py-10 text-center text-sm text-gray-500">
                                        Your suppression list is empty.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
<%- include('../partials/dashboard_footer') %>
