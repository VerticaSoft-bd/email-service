<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - <%= order.invoice_number %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9fafb;
        }

        .invoice-container {
            max-width: 48rem;
            margin: 2rem auto;
            background: white;
            padding: 3rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            border-radius: 0.5rem;
        }

        @media print {
            body {
                background: white;
                zoom: 90%;
            }

            .invoice-container {
                margin: 0;
                box-shadow: none;
                max-width: 100%;
                border-radius: 0;
                padding: 2rem;
            }

            .no-print {
                display: none !important;
            }
        }
    </style>
</head>

<body class="text-gray-900">

    <div class="max-w-3xl mx-auto mt-8 mb-4 flex justify-between items-center px-4 md:px-0 no-print">
        <a href="/dashboard/billing"
            class="text-indigo-600 hover:text-indigo-800 flex items-center text-sm font-medium">
            <i data-lucide="arrow-left" class="w-4 h-4 mr-1"></i> Back to Billing
        </a>
        <button onclick="window.print()"
            class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
            <i data-lucide="printer" class="w-4 h-4 mr-2"></i> Print / Download PDF
        </button>
    </div>

    <div class="invoice-container border border-gray-200">
        <!-- Header -->
        <div class="flex justify-between items-start border-b border-gray-200 pb-8 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-indigo-600 tracking-tight">VerticaSoft Email Service</h1>
                <p class="text-gray-500 text-sm mt-1">Professional Email Infrastructure</p>
                <div class="mt-4 text-sm text-gray-600">
                    <p>VerticaSoft Ltd.</p>
                    <p>123 Tech Park, Dhaka, BD</p>
                    <p>support@verticasoft.com</p>
                </div>
            </div>
            <div class="text-right">
                <h2 class="text-4xl font-light text-gray-300 uppercase tracking-widest mb-2">Invoice</h2>
                <div class="text-sm">
                    <p class="font-medium text-gray-900">Invoice Number: <span class="font-normal text-gray-600">
                            <%= order.invoice_number %>
                        </span></p>
                    <p class="font-medium text-gray-900 mt-1">Date: <span class="font-normal text-gray-600">
                            <%= new Date(order.createdAt).toLocaleDateString() %>
                        </span></p>
                    <% if(order.status==='completed' ) { %>
                        <p
                            class="mt-2 text-green-600 font-bold uppercase tracking-wider text-xs border border-green-200 bg-green-50 px-2 py-1 inline-block rounded">
                            Paid</p>
                        <% } else if(order.status==='failed' ) { %>
                            <p
                                class="mt-2 text-red-600 font-bold uppercase tracking-wider text-xs border border-red-200 bg-red-50 px-2 py-1 inline-block rounded">
                                Failed</p>
                            <% } else { %>
                                <p
                                    class="mt-2 text-yellow-600 font-bold uppercase tracking-wider text-xs border border-yellow-200 bg-yellow-50 px-2 py-1 inline-block rounded">
                                    Pending</p>
                                <% } %>
                </div>
            </div>
        </div>

        <!-- Billing Info -->
        <div class="grid grid-cols-2 gap-8 mb-8">
            <div>
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Billed To</h3>
                <p class="text-gray-900 font-medium">
                    <%= user.name || 'Valued Customer' %>
                </p>
                <p class="text-gray-600 text-sm">
                    <%= user.email %>
                </p>
            </div>
            <% if(order.trxId) { %>
                <div>
                    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Payment Details</h3>
                    <p class="text-sm text-gray-600">Gateway: PayStation BD</p>
                    <p class="text-sm text-gray-600">Transaction ID: <span class="font-mono text-xs">
                            <%= order.trxId %>
                        </span></p>
                </div>
                <% } %>
        </div>

        <!-- Line Items -->
        <table class="w-full text-left mb-8">
            <thead>
                <tr class="border-y border-gray-200 bg-gray-50">
                    <th class="py-3 px-4 text-xs font-semibold text-gray-500 uppercase">Description</th>
                    <th class="py-3 px-4 text-xs font-semibold text-gray-500 uppercase text-right">Amount</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <tr>
                    <td class="py-4 px-4 text-sm text-gray-900">
                        <span class="font-medium">Subscription Upgrade - <%= order.plan.charAt(0).toUpperCase() +
                                order.plan.slice(1) %> Plan</span>
                        <p class="text-gray-500 text-xs mt-1">1 Month subscription validity</p>
                    </td>
                    <td class="py-4 px-4 text-sm text-gray-900 text-right font-medium">৳<%= order.amount %>
                    </td>
                </tr>
            </tbody>
        </table>

        <!-- Totals -->
        <div class="flex justify-end">
            <div class="w-1/2 md:w-1/3 space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Subtotal</span>
                    <span class="text-gray-900 font-medium">৳<%= order.amount %></span>
                </div>
                <div class="flex justify-between text-sm pb-3 border-b border-gray-200">
                    <span class="text-gray-500">Tax (0%)</span>
                    <span class="text-gray-900 font-medium">৳0.00</span>
                </div>
                <div class="flex justify-between text-lg font-bold">
                    <span class="text-gray-900">Total</span>
                    <span class="text-indigo-600">৳<%= order.amount %></span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="mt-16 pt-8 border-t border-gray-200 text-center text-xs text-gray-500">
            <p>Thank you for doing business with us.</p>
            <p class="mt-1">For any inquiries, please contact support at support@verticasoft.com</p>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>

</html>