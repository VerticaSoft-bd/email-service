<%- include('../partials/dashboard_header', { title: 'Overview' , currentPath: '/dashboard' }) %>
    <h1 class="text-2xl font-semibold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Welcome back, <%= user.name %>. Here's what's happening today.</p>

    <div class="mt-8">
        <dl
            class="mt-5 grid grid-cols-1 rounded-lg bg-white overflow-hidden shadow divide-y divide-gray-200 md:grid-cols-3 md:divide-y-0 md:divide-x border border-gray-200">
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Total Domains</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-domains">
                            <%= typeof domainCount !=='undefined' ? domainCount : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Active Email Accounts</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-accounts">
                            <%= typeof accountCount !=='undefined' ? accountCount : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Emails Sent</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-emails">
                            <%= user.usage && user.usage.emailsSent ? user.usage.emailsSent : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
        </dl>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200">
        <div class="mb-4">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Quick Actions</h3>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <a href="/dashboard/domains"
                class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500 transition-colors">
                <div class="flex-shrink-0">
                    <i data-lucide="plus-circle" class="h-6 w-6 text-indigo-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Connect a Domain</p>
                    <p class="text-sm text-gray-500 truncate">Verify your custom domain using AWS SES</p>
                </div>
            </a>
            <a href="/dashboard/accounts"
                class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500 transition-colors">
                <div class="flex-shrink-0">
                    <i data-lucide="mail-plus" class="h-6 w-6 text-indigo-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Create Email Account</p>
                    <p class="text-sm text-gray-500 truncate">Generate info@, support@, etc.</p>
                </div>
            </a>
        </div>
    </div>
    <%- include('../partials/dashboard_footer') %>