<%- include('../partials/dashboard_header', { title: 'Overview' , currentPath: '/dashboard' }) %>
    <h1 class="text-2xl font-semibold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Welcome back, <%= user.name %>. Here's what's happening today.</p>

    <div class="mt-8">
        <dl
            class="mt-5 grid grid-cols-1 rounded-lg bg-white overflow-hidden shadow divide-y divide-gray-200 md:grid-cols-3 md:divide-y-0 md:divide-x border border-gray-200">
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Total Domains</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-domains">
                            <%= typeof domainCount !=='undefined' ? domainCount : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Active Email Accounts</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-accounts">
                            <%= typeof accountCount !=='undefined' ? accountCount : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dt class="text-base font-normal text-gray-900">Emails Sent</dt>
                <dd class="mt-1 flex justify-between items-baseline md:block lg:flex">
                    <div class="flex items-baseline text-2xl font-semibold text-indigo-600">
                        <span id="stat-emails">
                            <%= user.usage && user.usage.emailsSent ? user.usage.emailsSent : 0 %>
                        </span>
                    </div>
                </dd>
            </div>
        </dl>
    </div>

    <!-- PREMIUM PLAN USAGE SECTION -->
    <div class="mt-12">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h3 class="text-xl font-bold text-gray-900 tracking-tight">Resource Utilization</h3>
                <p class="text-sm text-gray-500 mt-1">Real-time status of your <%= (user.plan || 'starter') %> infrastructure</p>
            </div>
            <% if (user.plan === 'starter' || user.plan === 'pro') { %>
            <a href="/dashboard/billing" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-semibold rounded-lg shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition-all hover:scale-105">
                Upgrade Plan
            </a>
            <% } %>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
            <% 
                const plan = user.plan || 'starter';
                const limits = PLAN_LIMITS[plan];
                const stats = [
                    { 
                        name: 'Verified Domains', 
                        current: domainCount, 
                        limit: limits.domains,
                        icon: 'globe',
                        color: 'indigo'
                    },
                    { 
                        name: 'Active Identities', 
                        current: accountCount, 
                        limit: limits.identities,
                        icon: 'users',
                        color: 'purple'
                    },
                    { 
                        name: 'Monthly Outbound', 
                        current: user.usage?.emailsSent || 0, 
                        limit: limits.emailsPerMonth,
                        icon: 'send',
                        color: 'blue'
                    }
                ];
            %>

            <% stats.forEach(item => { %>
                <div class="relative group bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-indigo-100 transition-all duration-300">
                    <div class="flex items-center justify-between mb-4">
                        <div class="p-3 bg-<%= item.color %>-50 rounded-xl text-<%= item.color %>-600 group-hover:bg-<%= item.color %>-600 group-hover:text-white transition-colors duration-300">
                            <i data-lucide="<%= item.icon %>" class="w-6 h-6"></i>
                        </div>
                        <div class="text-right">
                            <div class="text-2xl font-black text-gray-900 leading-none">
                                <%= item.current %>
                            </div>
                            <div class="text-[10px] uppercase font-bold text-gray-400 tracking-widest mt-1">
                                <%= item.limit === -1 ? 'Unlimited' : `Allocated: ${item.limit}` %>
                            </div>
                        </div>
                    </div>

                    <h4 class="text-sm font-bold text-gray-700 mb-4"><%= item.name %></h4>

                    <div class="relative pt-1">
                        <% if (item.limit !== -1) { 
                            const percentage = Math.min((item.current / item.limit) * 100, 100);
                            let barColor = `bg-${item.color}-600`;
                            if (percentage >= 90) barColor = 'bg-red-500';
                            else if (percentage >= 75) barColor = 'bg-orange-500';
                        %>
                            <div class="overflow-hidden h-2.5 text-xs flex rounded-full bg-gray-100 mb-2">
                                <div style="width: <%= percentage %>%;" 
                                     class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center <%= barColor %> transition-all duration-700 ease-out relative">
                                     <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
                                </div>
                            </div>
                            <div class="flex justify-between text-[10px] font-bold text-gray-400">
                                <span>USAGE: <%= percentage.toFixed(1) %>%</span>
                                <span><%= item.limit - item.current %> REMAINING</span>
                            </div>
                        <% } else { %>
                            <div class="overflow-hidden h-2.5 text-xs flex rounded-full bg-<%= item.color %>-50 mb-2">
                                <div style="width: 100%;" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-<%= item.color %>-600"></div>
                            </div>
                            <div class="text-[10px] font-bold text-<%= item.color %>-600 uppercase tracking-widest">
                                Unlimited Access Included
                            </div>
                        <% } %>
                    </div>

                    <!-- Decorative background blob on hover -->
                    <div class="absolute -bottom-2 -right-2 w-20 h-20 bg-<%= item.color %>-50 rounded-full opacity-0 group-hover:opacity-100 transition-opacity blur-2xl -z-10"></div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200">
        <div class="mb-4">
            <h3 class="text-lg leading-6 font-medium text-gray-900">Quick Actions</h3>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <a href="/dashboard/domains"
                class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500 transition-colors">
                <div class="flex-shrink-0">
                    <i data-lucide="plus-circle" class="h-6 w-6 text-indigo-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Connect a Domain</p>
                    <p class="text-sm text-gray-500 truncate">Verify your custom domain using AWS SES</p>
                </div>
            </a>
            <a href="/dashboard/accounts"
                class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500 transition-colors">
                <div class="flex-shrink-0">
                    <i data-lucide="mail-plus" class="h-6 w-6 text-indigo-600"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Create Email Account</p>
                    <p class="text-sm text-gray-500 truncate">Generate info@, support@, etc.</p>
                </div>
            </a>
        </div>
    </div>
    <%- include('../partials/dashboard_footer') %>