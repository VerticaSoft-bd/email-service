<%- include('../partials/dashboard_header', { title: 'Domains' , currentPath: '/dashboard/domains' }) %>
    <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
            <h1 class="text-2xl font-semibold text-gray-900">Custom Domains</h1>
            <p class="mt-2 text-sm text-gray-700">Connect and verify your custom domains using AWS SES to start sending
                emails.</p>
        </div>
    </div>

    <div class="mt-8 bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
                Domain Verification Status
            </h3>

            <% if (error) { %>
                <div class="mt-4 bg-red-50 border-l-4 border-red-400 p-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-700">
                                <%= error %>
                            </p>
                        </div>
                    </div>
                </div>
                <% } %>

                    <% if (statusMessage) { %>
                        <div class="mt-4 bg-blue-50 border-l-4 border-blue-400 p-4">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <i data-lucide="info" class="h-5 w-5 text-blue-400"></i>
                                </div>
                                <div class="ml-3">
                                    <p class="text-sm text-blue-700">
                                        <%= statusMessage %>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <% } %>

                            <div class="mt-5 max-w-xl">
                                <% if (!user.domainVerified) { %>
                                    <form action="/dashboard/domains/verify" method="POST"
                                        class="sm:flex sm:items-center">
                                        <div class="w-full sm:max-w-xs">
                                            <label for="domain" class="sr-only">Domain</label>
                                            <input type="text" name="domain" id="domain"
                                                class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md"
                                                placeholder="example.com" value="<%= user.domain || '' %>" required>
                                        </div>
                                        <button type="submit"
                                            class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                                            <%= user.verificationToken ? 'Regenerate Records' : 'Verify Domain' %>
                                        </button>
                                    </form>
                                    <% } else { %>
                                        <div
                                            class="flex items-center space-x-3 text-sm font-medium text-green-600 bg-green-50 p-4 rounded-md border border-green-200">
                                            <i data-lucide="check-circle" class="h-5 w-5"></i>
                                            <span>Your domain <strong>
                                                    <%= user.domain %>
                                                </strong> is verified and active!</span>
                                        </div>
                                        <% } %>
                            </div>

                            <% if (dnsRecords && dnsRecords.length> 0) { %>
                                <div class="mt-8">
                                    <div class="flex items-center justify-between">
                                        <h4 class="text-md font-medium text-gray-900">Required DNS Records</h4>
                                        <% if (!user.domainVerified) { %>
                                            <a href="/dashboard/domains/status"
                                                class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                                <i data-lucide="refresh-cw" class="h-4 w-4 mr-1.5 text-gray-400"></i>
                                                Check Status
                                            </a>
                                            <% } %>
                                    </div>
                                    <p class="mt-1 text-sm text-gray-500">Add the following records to your domain's DNS
                                        settings.</p>

                                    <div class="mt-4 flex flex-col">
                                        <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                                            <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                                                <div
                                                    class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                                                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                                                        <thead class="bg-gray-50">
                                                            <tr>
                                                                <th scope="col"
                                                                    class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                    Type</th>
                                                                <th scope="col"
                                                                    class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                    Name / Host</th>
                                                                <th scope="col"
                                                                    class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                    Value</th>
                                                                <th scope="col"
                                                                    class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                    Purpose</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody
                                                            class="bg-white divide-y divide-gray-200 font-mono text-xs">
                                                            <% dnsRecords.forEach(record=> { %>
                                                                <tr>
                                                                    <td class="px-6 py-4 whitespace-nowrap"><span
                                                                            class="px-2 inline-flex leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800">
                                                                            <%= record.type %>
                                                                        </span></td>
                                                                    <td
                                                                        class="px-6 py-4 break-all max-w-xs text-gray-900">
                                                                        <%= record.name %>
                                                                    </td>
                                                                    <td
                                                                        class="px-6 py-4 break-all text-gray-500 select-all">
                                                                        <%= record.value %>
                                                                    </td>
                                                                    <td
                                                                        class="px-6 py-4 whitespace-nowrap text-gray-500 font-sans">
                                                                        <%= record.purpose %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
        </div>
    </div>
    <%- include('../partials/dashboard_footer') %>