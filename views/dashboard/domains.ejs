<%- include('../partials/dashboard_header', { title: 'Domains' , currentPath: '/dashboard/domains' }) %>
    <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
            <h1 class="text-2xl font-semibold text-gray-900">Custom Domains</h1>
            <p class="mt-2 text-sm text-gray-700">Add and manage multiple domains to send emails from different
                identities.</p>
        </div>
    </div>

    <% if (error) { %>
        <div class="mt-4 bg-red-50 border-l-4 border-red-400 p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700">
                        <%= error %>
                    </p>
                </div>
            </div>
        </div>
        <% } %>

            <% if (statusMessage) { %>
                <div class="mt-4 bg-blue-50 border-l-4 border-blue-400 p-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="info" class="h-5 w-5 text-blue-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-blue-700">
                                <%= statusMessage %>
                            </p>
                        </div>
                    </div>
                </div>
                <% } %>

                    <!-- Add New Domain -->
                    <div class="mt-8 bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
                        <div class="px-4 py-5 sm:p-6">
                            <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Add a New Domain</h3>
                            <form action="/dashboard/domains/verify" method="POST" class="sm:flex sm:items-center">
                                <div class="w-full sm:max-w-xs transition-all">
                                    <label for="domainName" class="sr-only">Domain</label>
                                    <input type="text" name="domainName" id="domainName"
                                        class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md px-3 py-2 border"
                                        placeholder="example.com" required>
                                </div>
                                <button type="submit"
                                    class="mt-3 w-full inline-flex justify-center px-4 py-2 border border-transparent shadow-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-colors">
                                    Add & Generate Records
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- List of Domains -->
                    <% if (domains && domains.length> 0) { %>
                        <div class="mt-8 flex flex-col space-y-8">
                            <% domains.forEach(domainObj=> { %>
                                <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
                                    <div
                                        class="px-4 py-5 border-b border-gray-200 sm:px-6 flex justify-between items-center bg-gray-50">
                                        <div class="flex items-center">
                                            <i data-lucide="globe"
                                                class="h-5 w-5 mr-2 <%= domainObj.isVerified ? 'text-green-500' : 'text-yellow-500' %>"></i>
                                            <h3 class="text-lg leading-6 font-medium text-gray-900">
                                                <%= domainObj.domain %>
                                            </h3>
                                            <% if (domainObj.isVerified) { %>
                                                <span
                                                    class="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Verified
                                                    & Active</span>
                                                <% } else { %>
                                                    <span
                                                        class="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending
                                                        Verification</span>
                                                    <% } %>
                                        </div>
                                        <div class="flex space-x-2 border-transparent">
                                            <% if (!domainObj.isVerified) { %>
                                                <a href="/dashboard/domains/<%= domainObj._id %>/status"
                                                    class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                                    <i data-lucide="refresh-cw"
                                                        class="h-4 w-4 mr-1.5 text-gray-400"></i> Check Status
                                                </a>
                                                <% } %>
                                                    <form action="/dashboard/domains/<%= domainObj._id %>/delete"
                                                        method="POST"
                                                        onsubmit="return confirm('Delete this domain entirely? All associated email accounts may stop functioning.');">
                                                        <button type="submit"
                                                            class="inline-flex items-center px-3 py-1.5 shadow-sm text-sm font-medium rounded text-red-600 bg-red-50 hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-offset-2 border border-transparent border-red-100 focus:ring-red-500 transition-colors">
                                                            <i data-lucide="trash-2" class="h-4 w-4"></i>
                                                        </button>
                                                    </form>
                                        </div>
                                    </div>

                                    <% if (!domainObj.isVerified && domainObj.dnsRecords && domainObj.dnsRecords.length>
                                        0) { %>
                                        <div class="px-4 py-5 sm:p-6">
                                            <p class="text-sm text-gray-500 mb-4">Add the following records to this
                                                domain's DNS settings.</p>
                                            <div class="flex flex-col">
                                                <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                                                    <div
                                                        class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                                                        <div
                                                            class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                                                            <table class="min-w-full divide-y divide-gray-200 text-sm">
                                                                <thead class="bg-gray-50">
                                                                    <tr>
                                                                        <th scope="col"
                                                                            class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                            Type</th>
                                                                        <th scope="col"
                                                                            class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                            Name / Host</th>
                                                                        <th scope="col"
                                                                            class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                            Value</th>
                                                                        <th scope="col"
                                                                            class="px-6 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                                                                            Purpose</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody
                                                                    class="bg-white divide-y divide-gray-200 font-mono text-xs">
                                                                    <% domainObj.dnsRecords.forEach(record=> { %>
                                                                        <tr>
                                                                            <td class="px-6 py-4 whitespace-nowrap">
                                                                                <span
                                                                                    class="px-2 inline-flex leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800">
                                                                                    <%= record.type %>
                                                                                </span>
                                                                            </td>
                                                                            <td
                                                                                class="px-6 py-4 break-all max-w-xs text-gray-900">
                                                                                <div
                                                                                    class="flex items-center justify-between space-x-1">
                                                                                    <span>
                                                                                        <%= record.name %>
                                                                                    </span>
                                                                                    <button
                                                                                        onclick="copyDomainText(this, '<%= record.name %>')"
                                                                                        class="flex-shrink-0 p-1 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors"
                                                                                        title="Copy Name">
                                                                                        <i data-lucide="copy"
                                                                                            class="h-4 w-4"></i>
                                                                                    </button>
                                                                                </div>
                                                                            </td>
                                                                            <td
                                                                                class="px-6 py-4 break-all text-gray-500 select-all">
                                                                                <div
                                                                                    class="flex items-center justify-between space-x-1">
                                                                                    <span>
                                                                                        <%= record.value %>
                                                                                    </span>
                                                                                    <button
                                                                                        onclick="copyDomainText(this, '<%= record.value %>')"
                                                                                        class="flex-shrink-0 p-1 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors"
                                                                                        title="Copy Value">
                                                                                        <i data-lucide="copy"
                                                                                            class="h-4 w-4"></i>
                                                                                    </button>
                                                                                </div>
                                                                            </td>
                                                                            <td
                                                                                class="px-6 py-4 whitespace-nowrap text-gray-500 font-sans">
                                                                                <%= record.purpose %>
                                                                            </td>
                                                                        </tr>
                                                                        <% }) %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <div
                                class="mt-8 text-center bg-gray-50 py-12 rounded-lg border-2 border-dashed border-gray-300">
                                <i data-lucide="globe" class="mx-auto h-12 w-12 text-gray-400"></i>
                                <h3 class="mt-2 text-sm font-medium text-gray-900">No domains added</h3>
                                <p class="mt-1 text-sm text-gray-500">Get started by adding a custom domain above.</p>
                            </div>
                            <% } %>

                                <script>
                                    function copyDomainText(button, text) {
                                        navigator.clipboard.writeText(text).then(() => {
                                            const originalHTML = button.innerHTML;
                                            button.innerHTML = '<i data-lucide="check" class="h-4 w-4 text-green-500"></i>';
                                            if (typeof lucide !== 'undefined') {
                                                lucide.createIcons();
                                            }
                                            setTimeout(() => {
                                                button.innerHTML = originalHTML;
                                            }, 2000);
                                        });
                                    }
                                </script>

                                <%- include('../partials/dashboard_footer') %>