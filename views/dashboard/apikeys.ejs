<%- include('../partials/dashboard_header', { title: 'API Keys' , currentPath: '/dashboard/apikeys' }) %>
    <div class="sm:flex sm:items-center justify-between">
        <div class="sm:flex-auto">
            <h1 class="text-2xl font-semibold text-gray-900">API Keys</h1>
            <p class="mt-2 text-sm text-gray-700">Generate API keys to authenticate your application for sending
                transactional emails.</p>
        </div>
    </div>

    <% if (plainKey) { %>
        <div class="mt-8 bg-green-50 border border-green-200 rounded-md p-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="check-circle" class="h-6 w-6 text-green-400"></i>
                </div>
                <div class="ml-3 flex-1">
                    <h3 class="text-sm font-medium text-green-800">API Key Created Successfully</h3>
                    <div class="mt-2 text-sm text-green-700">
                        <p>Please copy this key and save it somewhere safe. For security reasons, <strong>we will not
                                show it again.</strong></p>
                    </div>
                    <div class="mt-4 flex shadow-sm rounded-md">
                        <input type="text" readonly value="<%= plainKey %>"
                            class="form-input flex-1 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300 bg-white font-mono px-3 py-2 border select-all focus:outline-none"
                            onclick="this.select()">
                    </div>
                </div>
            </div>
        </div>
        <% } %>

            <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
                <!-- Quick Create Form -->
                <div class="bg-white shadow sm:rounded-lg lg:col-span-1 border border-gray-200 self-start">
                    <div class="px-4 py-5 sm:p-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Create New API Key</h3>
                        <p class="mt-1 text-sm text-gray-500">Keys give full access to send emails via our API.</p>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="mt-4 bg-red-50 border-l-4 border-red-400 p-4">
                                <p class="text-sm text-red-700">
                                    <%= error %>
                                </p>
                            </div>
                            <% } %>

                                <form action="/dashboard/apikeys" method="POST" class="mt-5 sm:flex sm:items-center">
                                    <div class="w-full sm:max-w-xs">
                                        <label for="name" class="sr-only">Key Name</label>
                                        <input type="text" name="name" id="name"
                                            class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border border-gray-300 rounded-md py-2 px-3"
                                            placeholder="e.g. Production Web App" required>
                                    </div>
                                    <button type="submit"
                                        class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                                        Generate Key
                                    </button>
                                </form>
                    </div>
                </div>

                <!-- API Keys List -->
                <div class="bg-white shadow sm:rounded-lg lg:col-span-2 border border-gray-200">
                    <div class="px-4 py-5 border-b border-gray-200 sm:px-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Active Keys</h3>
                    </div>
                    <ul role="list" class="divide-y divide-gray-200">
                        <% if (apikeys && apikeys.length> 0) { %>
                            <% apikeys.forEach(apiKey=> { %>
                                <li
                                    class="px-4 py-4 sm:px-6 flex items-center justify-between hover:bg-gray-50 transition-colors">
                                    <div class="flex flex-col">
                                        <p class="text-sm font-medium text-gray-900">
                                            <%= apiKey.name %>
                                        </p>
                                        <div class="flex items-center mt-1 space-x-2 text-xs text-gray-500">
                                            <span
                                                class="font-mono bg-gray-100 px-1.5 py-0.5 rounded border border-gray-200">
                                                <%= apiKey.prefix %>************************
                                            </span>
                                        </div>
                                        <p class="text-xs text-gray-400 mt-1">Created <%= new
                                                Date(apiKey.createdAt).toLocaleDateString() %>
                                        </p>
                                    </div>
                                    <div class="ml-4 flex-shrink-0 flex items-center justify-center space-x-2">
                                        <form action="/dashboard/apikeys/<%= apiKey._id %>/delete" method="POST"
                                            onsubmit="return confirm('Are you sure you want to revoke this API key? Any applications using it will immediately lose access.');">
                                            <button type="submit"
                                                class="inline-flex items-center px-2.5 py-1.5 border border-red-300 shadow-sm text-xs font-medium rounded text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors">
                                                Revoke
                                            </button>
                                        </form>
                                    </div>
                                </li>
                                <% }) %>
                                    <% } else { %>
                                        <li class="px-4 py-8 text-center sm:px-6 text-gray-500 text-sm">
                                            No active API keys found. Create one to start using the API.
                                        </li>
                                        <% } %>
                    </ul>
                </div>
            </div>
            <%- include('../partials/dashboard_footer') %>